# Yerel sunucu / admin paneli
ADMIN_PASSWORD=patygo-admin
PORT=5173
SITE_BASE_URL=https://patygoteknoloji.com
# Admin oturumu: son işlemden sonra (ms). Varsayılan 30 dakika.
# ADMIN_IDLE_MS=1800000

# Tedarikçi XML (gerçek bağlantıyı yalnızca .env veya admin panelinden kaydedin)
SUPPLIER_XML_URL=
SUPPLIER_XML_URL_2=
SUPPLIER_XML_URL_3=
# Üç kaynağın alan adlarını virgülle ayırın
SUPPLIER_ALLOWED_HOSTS=www.bilgisayarim.com.tr
SUPPLIER_MARGIN_PERCENT=15

# Akbank SecurePay (sanalpos.akbank.com → MerchantSafeID / TerminalSafeID / Secret Key)
# Anahtarları sohbete yapıştırmayın; yalnızca bu .env dosyasına yazın.
AKBANK_MERCHANT_SAFE_ID=
AKBANK_TERMINAL_SAFE_ID=
AKBANK_SECRET_KEY=
# true = test (apipre / payhosting pre), false = canlı
AKBANK_TEST_MODE=true
# Desteklenen model: 3D_PAY_HOSTING (kart banka sayfasında)
AKBANK_PAYMENT_MODEL=3D_PAY_HOSTING
